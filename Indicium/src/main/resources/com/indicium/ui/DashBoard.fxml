<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<fx:root prefHeight="650.0" prefWidth="1000.0"
         stylesheets="@Dashboard.css"
         type="BorderPane"
         xmlns="http://javafx.com/javafx/25"
         xmlns:fx="http://javafx.com/fxml/1">

    <!-- ═══════════════════════════ TOP NAV ═══════════════════════════ -->
    <top>
        <HBox id="TopNavBar" alignment="CENTER_LEFT"
              prefHeight="60.0" prefWidth="1000.0" spacing="10.0">
            <padding><Insets left="20.0" right="20.0" /></padding>

            <!-- Menu toggle — replaces static logo -->
            <Button fx:id="btnMenuToggle"
                    onAction="#handleMenuToggle"
                    styleClass="menu-toggle-btn">
                <graphic>
                    <ImageView fitHeight="28.0" fitWidth="28.0"
                               pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@Assets/icons8-menu-50.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <!-- App name -->
            <Label styleClass="app-title" text="INDICIUM">
                <HBox.margin><Insets left="6.0" /></HBox.margin>
            </Label>

            <!-- Spacer -->
            <HBox HBox.hgrow="ALWAYS" />

            <!-- Top nav buttons -->
            <Button fx:id="navDashboard" onAction="#handleNavDashboard"
                    styleClass="top-nav-btn" text="Dashboard" />
            <Button fx:id="navNotes"     onAction="#handleNavNotes"
                    styleClass="top-nav-btn" text="Notes" />
            <Button fx:id="navVideos"    onAction="#handleNavVideos"
                    styleClass="top-nav-btn" text="Search" />
            <Button fx:id="navTools"     onAction="#handleNavTools"
                    styleClass="top-nav-btn" text="Tools" />
            <Button fx:id="navForum"     onAction="#handleNavForum"
                    styleClass="top-nav-btn">
                <graphic>
                    <ImageView fitHeight="24.0" fitWidth="24.0"
                               pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@Assets/icons8-notification-100%20(1).png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <!-- User avatar -->
            <StackPane styleClass="avatar-circle">
                <Label styleClass="avatar-label" text="B" />
            </StackPane>

        </HBox>
    </top>

    <!-- ═══════════════════════════ CENTER ═══════════════════════════ -->
    <center>
        <StackPane fx:id="centerPane" />
    </center>

    <!-- ═══════════════════════════ SIDEBAR ══════════════════════════ -->
    <left>
        <VBox fx:id="sideNavBar"
              prefWidth="210.0" minWidth="56.0"
              spacing="4.0"
              styleClass="side-nav-bar"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" left="10.0" right="10.0" top="16.0" />
            </padding>

            <Button fx:id="sideHome" onAction="#handleNavDashboard"
                    styleClass="side-nav-btn,side-active"
                    text="Dashboard" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-home-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideCases" onAction="#handleSideCases"
                    styleClass="side-nav-btn"
                    text="Cases" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-case-100%20(1).png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideEvidence" onAction="#handleSideEvidence"
                    styleClass="side-nav-btn"
                    text="Evidence" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-evidence-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideTimeline" onAction="#handleSideTimeline"
                    styleClass="side-nav-btn"
                    text="Timeline" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-timeline-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideAuditLog" onAction="#handleSideAuditLog"
                    styleClass="side-nav-btn"
                    text="Audit Log" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-audit-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideReport" onAction="#handleSideReport"
                    styleClass="side-nav-btn"
                    text="Report" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-report-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <!-- Spacer -->
            <VBox VBox.vgrow="ALWAYS" />

            <Button fx:id="sideSettings" onAction="#handleSideSettings"
                    styleClass="side-nav-btn"
                    text="Settings" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-settings-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideIntegrity" onAction="#handleSideIntegrity"
                    styleClass="side-nav-btn"
                    text="Integrity Manager" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image><Image url="@Assets/icons8-integrity-100.png" /></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="sideUserMgr" onAction="#handleSideUserManager"
                    styleClass="side-nav-btn"
                    text="User Manager" maxWidth="Infinity">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0"
                               preserveRatio="true">
                        <image>
                            <Image url="@Assets/icons8-accessibility-tools-100.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>

        </VBox>
    </left>

</fx:root>
