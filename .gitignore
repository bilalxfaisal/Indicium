# --- IntelliJ IDEA ---
.idea/**
# Un-ignore the "soul" of the project structure so it works on other laptops
!.idea/modules.xml
!.idea/compiler.xml
!.idea/misc.xml
!.idea/vcs.xml

# Ignore all other IDE metadata/temp files
.idea/*.xml
.idea/libraries/
.idea/shelf/
.idea/workspace.xml
*.iml
*.iws
*.ipr

# --- Build & Output ---
out/
target/
build/
bin/

# --- OS Specific ---
.DS_Store
Thumbs.db
desktop.ini

# --- Indicium Specific (Database & Logs) ---
*.db
*.log
/evidence_storage/
config.properties

# IMPORTANT: Ignore your personal password file
database.properties

# Ignore general SQL dumps, but KEEP the team setup script
*.sql
!database_scripts/setup.sql

# Ensure the library JARs are tracked so teammates have the MySQL driver
!lib/*.jar
