<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<fx:root type="BorderPane"
         xmlns="http://javafx.com/javafx/25"
         xmlns:fx="http://javafx.com/fxml/1"
         styleClass="id-root"
         stylesheets="@IdentityManager.css">

    <!-- ══ TOP BAR ══ -->
    <top>
        <HBox styleClass="id-topbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="16" bottom="16" left="24" right="24"/></padding>

            <VBox spacing="2">
                <Label text="Identity Manager" styleClass="id-page-title"/>
                <Label text="Create, modify and revoke system user accounts" styleClass="id-page-sub"/>
            </VBox>

            <HBox HBox.hgrow="ALWAYS"/>

            <!-- Search bar -->
            <HBox styleClass="id-search-box" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="6" bottom="6" left="12" right="12"/></padding>
                <ImageView fitHeight="14" fitWidth="14" preserveRatio="true" opacity="0.5">
                    <image><Image url="@Assets/icons8-search-100.png"/></image>
                </ImageView>
                <TextField fx:id="searchField"
                           styleClass="id-search-input"
                           promptText="Search users…"/>
            </HBox>

            <!-- Role filter -->
            <ComboBox fx:id="roleFilter"
                      styleClass="id-combo"
                      promptText="All Roles"
                      onAction="#handleRoleFilter"/>

            <!-- Add user button -->
            <Button text="+ New User"
                    styleClass="id-btn-primary"
                    onAction="#handleNewUser"/>
        </HBox>
    </top>

    <!-- ══ MAIN CONTENT ══ -->
    <center>
        <SplitPane fx:id="splitPane" dividerPositions="0.65" styleClass="id-split">

            <!-- ── LEFT: User Table ── -->
            <VBox styleClass="id-panel" spacing="0">

                <!-- Stats row -->
                <HBox styleClass="id-stats-row" spacing="12">
                    <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>

                    <VBox styleClass="id-stat-card" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statTotal" text="0" styleClass="id-stat-number"/>
                        <Label text="Total Users"        styleClass="id-stat-label"/>
                    </VBox>
                    <VBox styleClass="id-stat-card" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statActive" text="0" styleClass="id-stat-number id-stat-green"/>
                        <Label text="Active"             styleClass="id-stat-label"/>
                    </VBox>
                    <VBox styleClass="id-stat-card" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statInvestigators" text="0" styleClass="id-stat-number id-stat-cyan"/>
                        <Label text="Investigators"      styleClass="id-stat-label"/>
                    </VBox>
                    <VBox styleClass="id-stat-card" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statAdmins" text="0" styleClass="id-stat-number id-stat-orange"/>
                        <Label text="Admins"             styleClass="id-stat-label"/>
                    </VBox>
                </HBox>

                <Separator styleClass="id-divider"/>

                <!-- Table -->
                <TableView fx:id="userTable"
                           styleClass="id-table"
                           VBox.vgrow="ALWAYS"
                           onMouseClicked="#handleTableClick">

                    <columns>
                        <TableColumn fx:id="colId"     text="ID"           prefWidth="60"  styleClass="id-col"/>
                        <TableColumn fx:id="colName"   text="Name"         prefWidth="160" styleClass="id-col"/>
                        <TableColumn fx:id="colEmail"  text="Email"        prefWidth="200" styleClass="id-col"/>
                        <TableColumn fx:id="colRole"   text="Role"         prefWidth="120" styleClass="id-col"/>
                        <TableColumn fx:id="colStatus" text="Status"       prefWidth="100" styleClass="id-col"/>
                        <TableColumn fx:id="colLast"   text="Last Login"   prefWidth="140" styleClass="id-col"/>
                    </columns>

                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <padding><Insets top="40" bottom="40"/></padding>
                            <Label text="No users found" styleClass="id-empty-text"/>
                            <Label text="Try a different filter or create a new user" styleClass="id-empty-sub"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- ── RIGHT: Detail / Edit Panel ── -->
            <VBox fx:id="detailPanel" styleClass="id-detail-panel" spacing="0">

                <!-- Panel header -->
                <HBox styleClass="id-detail-header" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>
                    <Label fx:id="detailTitle" text="User Details" styleClass="id-detail-title"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnEdit"   text="Edit"   styleClass="id-btn-secondary" onAction="#handleEdit"   visible="false"/>
                    <Button fx:id="btnCancel" text="Cancel" styleClass="id-btn-ghost"     onAction="#handleCancel" visible="false" managed="false"/>
                </HBox>

                <Separator styleClass="id-divider"/>

                <ScrollPane fitToWidth="true" styleClass="id-scroll" VBox.vgrow="ALWAYS">
                    <VBox spacing="20">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                        <!-- Avatar + name row -->
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <StackPane styleClass="id-avatar-lg">
                                <Label fx:id="avatarLabel" text="?" styleClass="id-avatar-lg-text"/>
                            </StackPane>
                            <VBox spacing="4">
                                <Label fx:id="detailName"  text="Select a user" styleClass="id-detail-name"/>
                                <Label fx:id="detailRole"  text=""              styleClass="id-role-badge"/>
                            </VBox>
                        </HBox>

                        <Separator styleClass="id-divider"/>

                        <!-- Form fields -->
                        <VBox spacing="14">

                            <VBox spacing="4">
                                <Label text="Full Name" styleClass="id-field-label"/>
                                <TextField fx:id="fieldName"  styleClass="id-field" promptText="Full name"  editable="false"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Email Address" styleClass="id-field-label"/>
                                <TextField fx:id="fieldEmail" styleClass="id-field" promptText="Email"      editable="false"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Role" styleClass="id-field-label"/>
                                <ComboBox fx:id="fieldRole" styleClass="id-field-combo" maxWidth="Infinity" disable="true"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Clearance Level" styleClass="id-field-label"/>
                                <ComboBox fx:id="fieldClearance" styleClass="id-field-combo" maxWidth="Infinity" disable="true"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Status" styleClass="id-field-label"/>
                                <ComboBox fx:id="fieldStatus" styleClass="id-field-combo" maxWidth="Infinity" disable="true"/>
                            </VBox>

                        </VBox>

                        <Separator styleClass="id-divider"/>

                        <!-- Action buttons -->
                        <VBox spacing="10">
                            <Button fx:id="btnSave"   text="Save Changes"  styleClass="id-btn-primary"  maxWidth="Infinity" onAction="#handleSave"   visible="false" managed="false"/>
                            <Button fx:id="btnRevoke" text="Revoke Access" styleClass="id-btn-danger"   maxWidth="Infinity" onAction="#handleRevoke" visible="false"/>
                            <Button fx:id="btnReset"  text="Reset Password" styleClass="id-btn-secondary" maxWidth="Infinity" onAction="#handleReset" visible="false"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>

        </SplitPane>
    </center>

</fx:root>
